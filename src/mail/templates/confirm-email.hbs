<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Your Zenflow Verification Code</title>

    <style>
      /* Geist-like system fallback stack */
      @font-face {
        font-family: "Geist";
        src: local("Geist"), local("Geist Variable");
      }

      body {
        background-color: #f6f6f6;
        margin: 0;
        padding: 40px 0;
        font-family:
          "Geist",
          -apple-system,
          BlinkMacSystemFont,
          "Segoe UI",
          Roboto,
          Helvetica,
          Arial,
          sans-serif;
        color: #111;
      }

      .email-wrapper {
        max-width: 600px;
        margin: auto;
        background: #ffffff;
        border-radius: 12px;
        padding: 32px;
        border: 1px solid #e5e5e5;
      }

      .logo {
        text-align: center;
        margin-bottom: 28px;
        font-weight: 600;
        font-size: 26px;
      }

      .content {
        font-size: 15px;
        line-height: 1.7;
        color: #333;
      }

      .otp-box {
        margin: 32px auto;
        padding: 24px;
        border-radius: 10px;
        border: 1px solid #e5e5e5;
        font-size: 32px;
        font-weight: 600;
        letter-spacing: 6px;
        text-align: center;
        background: #fafafa;
      }

      .footer {
        margin-top: 32px;
        text-align: center;
        font-size: 12px;
        color: #888;
      }
    </style>
  </head>

  <body>
    <div class="email-wrapper">
      <div class="logo">Zenflow</div>

      <div class="content">
        <p>Hi,</p>

        <p>
          Welcome to
          <strong>Zenflow</strong>
          — we’re glad you’re here!
        </p>

        <p>Use the one-time verification code below to confirm your email:</p>

        <div class="otp-box">{{otp}}</div>

        <p>
          This code expires in 15 minutes. Please keep it private and do not
          share it with anyone.
        </p>

        <p>
          If you didn’t request this code, you can safely ignore this email.
        </p>

        <p>Thanks,<br />The Zenflow Team</p>
      </div>

      <div class="footer">© 2025 Zenflow. All rights reserved.</div>
    </div>
  </body>
</html>