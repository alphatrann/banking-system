{
  "name": "payment-system",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start:api": "nest start -c nest-cli.api.json",
    "start:outbox": "nest start -c nest-cli.outbox.json",
    "start:mail": "nest start -c nest-cli.mail.json",
    "start:receipt": "nest start -c nest-cli.receipt.json",
    "start:dev:api": "nest start -c nest-cli.api.json --watch",
    "start:dev:outbox": "nest start -c nest-cli.outbox.json --watch",
    "start:dev:mail": "nest start -c nest-cli.mail.json --watch",
    "start:dev:receipt": "nest start -c nest-cli.receipt.json --watch",
    "start:debug:api": "nest start -c nest-cli.api.json --debug --watch",
    "start:debug:outbox": "nest start -c nest-cli.outbox.json --debug --watch",
    "start:debug:mail": "nest start -c nest-cli.mail.json --debug --watch",
    "start:debug:receipt": "nest start -c nest-cli.receipt.json --debug --watch",
    "start:prod:api": "node dist/main.api",
    "start:prod:outbox": "node dist/main.outbox",
    "start:prod:mail": "node dist/main.mail",
    "start:prod:receipt": "node dist/main.receipt",
    "migrate:dev": "dotenv -e .env.development.local -- npx prisma migrate dev",
    "studio:dev": "dotenv -e .env.development.local -- npx prisma studio",
    "studio:test": "dotenv -e .env.test.local -- npx prisma studio",
    "migrate:reset:dev": "dotenv -e .env.development.local -- npx prisma migrate reset --force",
    "migrate:reset:test": "dotenv -e .env.test.local -- npx prisma migrate reset --force",
    "migrate:deploy:local": "dotenv -e .env.development.local -- npx prisma migrate deploy",
    "migrate:deploy:test": "dotenv -e .env.test.local -- npx prisma migrate deploy",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs-modules/mailer": "^2.0.2",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "*",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.1",
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.1",
    "argon2": "^0.44.0",
    "bullmq": "^5.69.3",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "joi": "^18.0.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.18.0",
    "prisma": "^7.4.0",
    "redis": "^5.11.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@faker-js/faker": "^10.3.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
