// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id              String            @id @default(ulid())
  email           String            @unique
  password        String
  createdAt       DateTime          @default(now()) @map("created_at")
  ledgerEntries   LedgerEntry[]
  idempotencyKeys IdempotencyKey[]
  webhooks        WebhookEndpoint[]
  emailEvents     EmailEvent[]

  @@map("accounts")
}

model Transaction {
  id            String        @id @default(ulid())
  createdAt     DateTime      @default(now()) @map("created_at")
  ledgerEntries LedgerEntry[]
  receipt       Receipt?

  @@map("transactions")
}

model LedgerEntry {
  id             Int      @id @default(autoincrement())
  transactionId  String   @map("transaction_id")
  accountId      String   @map("account_id")
  amount         BigInt // Positive or negative
  runningBalance BigInt   @map("running_balance")
  createdAt      DateTime @default(now()) @map("created_at")

  transaction Transaction @relation(fields: [transactionId], references: [id])
  account     Account     @relation(fields: [accountId], references: [id])

  @@unique([transactionId, accountId])
  @@map("ledger_entries")
}

model OutboxEvent {
  id            String            @id @default(ulid())
  aggregateType String            @map("aggregate_type")
  aggregateId   String            @map("aggregate_id")
  eventType     String            @map("event_type")
  payload       Json              @db.JsonB
  status        OutboxEventStatus @default(Pending)
  nextRetryAt   DateTime?         @map("next_retry_at")
  attemptCount  Int               @default(0) @map("attempt_count")
  createdAt     DateTime          @default(now()) @map("created_at")
  processedAt   DateTime?         @map("processed_at")

  @@unique([aggregateId, eventType])
  @@map("outbox_events")
}

enum OutboxEventStatus {
  Pending
  Processing
  Delivered
  Failed
}

model WebhookEndpoint {
  id        String  @id @default(ulid())
  accountId String  @map("account_id")
  url       String
  secret    String
  active    Boolean @default(true)

  account Account        @relation(fields: [accountId], references: [id])
  events  WebhookEvent[]

  @@map("webhook_endpoints")
}

model EmailEvent {
  id           String      @id
  toAccountId  String      @map("to_account_id")
  payload      Json        @db.JsonB
  status       EventStatus @default(Pending)
  attemptCount Int         @default(0) @map("attempt_count")

  toAccount Account @relation(fields: [toAccountId], references: [id])

  sentAt    DateTime? @map("sent_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("email_event")
}

model WebhookEvent {
  id           String      @id
  endpointId   String      @map("endpoint_id")
  eventType    String      @map("event_type")
  payload      Json        @db.JsonB
  status       EventStatus @default(Pending)
  nextRetryAt  DateTime?   @map("next_retry_at")
  attemptCount Int         @default(0) @map("attempt_count")
  createdAt    DateTime    @default(now()) @map("created_at")

  endpoint WebhookEndpoint  @relation(fields: [endpointId], references: [id])
  attempts WebhookAttempt[]

  @@map("webhook_events")
}

enum EventStatus {
  Pending
  Processing
  Done
  Failed
}

model WebhookAttempt {
  id             String   @id @default(ulid())
  webhookEventId String   @map("webhook_event_id")
  responseStatus Int      @map("response_status")
  responseBody   Json     @map("response_body") @db.JsonB
  durationMs     Int      @map("duration_ms")
  createdAt      DateTime @default(now()) @map("created_at")

  webhookEvent WebhookEvent @relation(fields: [webhookEventId], references: [id])

  @@map("webhook_attempts")
}

model IdempotencyKey {
  accountId    String            @map("account_id")
  key          String
  requestHash  String            @map("request_hash")
  status       IdempotencyStatus @default(Processing)
  responseCode Int?              @map("response_code")
  responseBody Json              @map("response_body") @db.JsonB
  createdAt    DateTime          @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id])

  @@id([accountId, key])
  @@map("idempotency_keys")
}

enum IdempotencyStatus {
  Processing
  Completed
}

model File {
  id        String   @id @default(ulid())
  bucket    String
  object    String
  size      BigInt
  iv        String
  mimetype  String
  createdAt DateTime @default(now()) @map("created_at")
  receipt   Receipt?

  @@unique([bucket, object])
  @@map("files")
}

model Receipt {
  id            String   @id
  number        BigInt   @unique @default(autoincrement())
  fileId        String?  @unique @map("file_id")
  transactionId String   @unique @map("transaction_id")
  createdAt     DateTime @default(now()) @map("created_at")

  file         File?       @relation(fields: [fileId], references: [id])
  transaction  Transaction @relation(fields: [transactionId], references: [id])
  status       EventStatus @default(Pending)
  generatedAt  DateTime?   @map("generated_at")
  failedAt     DateTime?   @map("failed_at")
  failedReason String?     @map("failed_reason")

  @@map("receipts")
}
